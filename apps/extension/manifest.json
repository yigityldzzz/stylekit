{
  "manifest_version": 3,
  "name": "StyleKit",
  "version": "1.0.0",
  "description": "Automatically extract design tokens (colors, typography, spacing, shadows, border-radius) from any website and export as DESIGN.md",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StyleKit – Extract Design Tokens",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
